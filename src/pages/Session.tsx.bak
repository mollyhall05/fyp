import { useEffect, useState } from "react";
import { useParams, useNavigate, Link } from "react-router-dom";
import { motion } from "framer-motion";
import { supabase } from "@/integrations/supabase/client";
import { Button } from "@/components/ui/button";
import { useToast } from "@/hooks/use-toast";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import {
    Users, MapPin, Link2, ChevronLeft, Calendar, Clock, Video, UserPlus, CheckCircle2, ExternalLink, Copy, Smartphone,
    CalendarPlus, Share2, Bell, X
} from "lucide-react";

interface Session {
    id: string;
    title: string;
    description: string | null;
    datetime: string;
    duration_minutes: number;
    location: string | null;
    is_online: boolean;
    meeting_link: string | null;
    zoom_meeting_id?: string | null;
    zoom_join_url?: string | null;
    zoom_password?: string | null;
    zoom_host_url?: string | null;
    group_id: string;
    group_name?: string;
}

const Session = () => {
    const { sessionId } = useParams<{ sessionId: string }>();
    const [session, setSession] = useState<Session | null>(null);
    const [loading, setLoading] = useState(true);
    const [isJoining, setIsJoining] = useState(false);
    const [upcomingSessions, setUpcomingSessions] = useState<any[]>([]);
    const [rsvpStatus, setRsvpStatus] = useState<'attending' | 'not_attending' | null>(null);
    const [isUpdatingRsvp, setIsUpdatingRsvp] = useState(false);
    const [groupMembers, setGroupMembers] = useState<any[]>([]);
    const navigate = useNavigate();
    const { toast } = useToast();

    useEffect(() => {
        const fetchSession = async () => {
            if (!sessionId) return;
            
            setLoading(true);
            try {
                const { data: { user } } = await supabase.auth.getUser();
                if (!user) throw new Error('User not authenticated');

                // Fetch session with group info
                const { data: sessionData, error: sessionError } = await supabase
                    .from('study_sessions')
                    .select(`
                        *,
                        groups (name)
                    `)
                    .eq('id', sessionId)
                    .single();

                if (sessionError) throw sessionError;
                if (!sessionData) throw new Error('Session not found');

                const transformedSession: Session = {
                    id: sessionData.id,
                    title: sessionData.title,
                    description: sessionData.description,
                    datetime: sessionData.datetime,
                    duration_minutes: sessionData.duration_minutes || 60, // Default to 60 if not set
                    location: sessionData.location,
                    is_online: sessionData.is_online,
                    meeting_link: sessionData.meeting_link,
                    // Handle cases where Zoom fields might not exist yet (migration not applied)
                    zoom_meeting_id: (sessionData as any).zoom_meeting_id || null,
                    zoom_join_url: (sessionData as any).zoom_join_url || null,
                    zoom_password: (sessionData as any).zoom_password || null,
                    zoom_host_url: (sessionData as any).zoom_host_url || null,
                    group_id: sessionData.group_id,
                    group_name: (sessionData.groups as any)?.name || 'Unknown Group'
                };

                // Debug logging to check what data we're getting
                console.log('Session data from DB:', sessionData);
                console.log('Transformed session:', transformedSession);

                setSession(transformedSession);

                // Fetch upcoming sessions from the same group (excluding current session)
                try {
                    const { data: upcomingData, error: upcomingError } = await supabase
                        .from('study_sessions')
                        .select(`
                            *,
                            groups (name)
                        `)
                        .eq('group_id', transformedSession.group_id)
                        .neq('id', sessionId) // Exclude current session
                        .gte('datetime', new Date().toISOString()) // Only future sessions
                        .order('datetime', { ascending: true })
                        .limit(3); // Limit to 3 upcoming sessions

                    if (!upcomingError && upcomingData) {
                        const transformedUpcoming = upcomingData.map((session: any) => ({
                            ...session,
                            group_name: session.groups?.name || 'Unknown Group'
                        }));
                        setUpcomingSessions(transformedUpcoming);
                    }
                } catch (upcomingError) {
                    console.log('No upcoming sessions found or error fetching:', upcomingError);
                    // Don't show error toast for upcoming sessions, just leave empty
                }

                // Fetch user's RSVP status for this session
                try {
                    const { data: rsvpData, error: rsvpError } = await supabase
                        .from('session_rsvps')
                        .select('status')
                        .eq('session_id', sessionId)
                        .eq('user_id', user.id)
                        .single();

                    if (!rsvpError && rsvpData) {
                        setRsvpStatus(rsvpData.status);
                    }
                } catch (rsvpError) {
                    // No RSVP found, that's fine
                    console.log('No RSVP found for this session');
                }

                // Fetch group members and their RSVP status
                try {
                    const { data: membersData, error: membersError } = await supabase
                        .from('group_members')
                        .select(`
                            user_id,
                            is_admin,
                            users!inner (
                                id,
                                email,
                                username
                            )
                        `)
                        .eq('group_id', sessionData.group_id);

                    if (membersError) throw membersError;

                    // Fetch RSVP status for all members
                    const memberIds = membersData?.map(m => m.user_id) || [];
                    const { data: rsvpData, error: rsvpError } = await supabase
                        .from('session_rsvps')
                        .select('user_id, status')
                        .eq('session_id', sessionId)
                        .in('user_id', memberIds);

                    if (rsvpError) throw rsvpError;

                    // Combine member data with RSVP status
                    const membersWithRsvp = membersData?.map(member => {
                        const rsvp = rsvpData?.find(r => r.user_id === member.user_id);
                        return {
                            ...member.users,
                            is_admin: member.is_admin,
                            rsvp_status: rsvp?.status || null
                        };
                    }) || [];

                    setGroupMembers(membersWithRsvp);
                } catch (membersError) {
                    console.error('Error fetching group members:', membersError);
                    // Don't show error toast for members, just log it
                }
            } catch (error: any) {
                console.error('Error fetching session:', error);
                toast({
                    title: 'Error',
                    description: error.message || 'Failed to load session',
                    variant: 'destructive',
                });
            } finally {
                setLoading(false);
            }
        };

        fetchSession();
    }, [sessionId, toast]);

    const handleRsvp = async (status: 'attending' | 'not_attending') => {
        if (!session || !sessionId) return;
        
        setIsUpdatingRsvp(true);
        try {
            const { data: { user } } = await supabase.auth.getUser();
            if (!user) throw new Error('User not authenticated');

            // Upsert RSVP record
            const { error: rsvpError } = await supabase
                .from('session_rsvps')
                .upsert({
                    session_id: sessionId,
                    user_id: user.id,
                    status: status,
                    updated_at: new Date().toISOString()
                }, {
                    onConflict: 'session_id,user_id'
                });

            if (rsvpError) throw rsvpError;

            setRsvpStatus(status);
            toast({
                title: "RSVP Updated",
                description: `You have ${status === 'attending' ? 'confirmed' : 'declined'} your attendance`,
            });
        } catch (error: any) {
            console.error('Error updating RSVP:', error);
            toast({
                title: "Error",
                description: "Failed to update RSVP",
                variant: "destructive",
            });
        } finally {
            setIsUpdatingRsvp(false);
        }
    };

    const handleJoinSession = async () => {
        if (!session) return;
        
        console.log('Join session clicked. Session data:', session);
        console.log('Is online:', session.is_online);
        console.log('Zoom join URL:', session.zoom_join_url);
        console.log('Meeting link:', session.meeting_link);
        
        setIsJoining(true);
        try {
            // For Zoom meetings, open the Zoom join URL
            if (session.is_online && session.zoom_join_url) {
                console.log('Opening Zoom meeting:', session.zoom_join_url);
                window.open(session.zoom_join_url, '_blank', 'noopener,noreferrer');
                toast({
                    title: 'Opening Zoom...',
                    description: 'Redirecting you to the Zoom meeting',
                });
            } else if (session.is_online && session.meeting_link) {
                console.log('Opening meeting link:', session.meeting_link);
                window.open(session.meeting_link, '_blank', 'noopener,noreferrer');
                toast({
                    title: 'Opening meeting...',
                    description: 'Redirecting you to the meeting link',
                });
            } else {
                console.log('No meeting link found, showing generic join message');
                // For in-person sessions or sessions without links
                await new Promise(resolve => setTimeout(resolve, 1000));
                toast({
                    title: 'Joined!',
                    description: session.is_online 
                        ? 'You have joined this online session'
                        : 'You have marked yourself as attending this in-person session',
                });
            }
        } catch (error) {
            console.error('Error in handleJoinSession:', error);
            toast({
                title: 'Error',
                description: 'Failed to join session',
                variant: 'destructive',
            });
        } finally {
            setIsJoining(false);
        }
    };

    const handleCopyMeetingInfo = () => {
        if (!session) return;
        
        let meetingInfo = '';
        if (session.is_online && session.zoom_meeting_id) {
            meetingInfo = `Zoom Meeting\nMeeting ID: ${session.zoom_meeting_id}`;
            if (session.zoom_password) {
                meetingInfo += `\nPassword: ${session.zoom_password}`;
            }
            meetingInfo += `\nJoin URL: ${session.zoom_join_url}`;
        } else if (session.is_online && session.meeting_link) {
            meetingInfo = `Meeting Link: ${session.meeting_link}`;
        } else {
            meetingInfo = `Location: ${session.location || 'TBD'}`;
        }
        
        navigator.clipboard.writeText(meetingInfo);
        toast({
            title: 'Copied!',
            description: 'Meeting information copied to clipboard',
        });
    };

    const handleCopyJoinUrl = () => {
        if (!session?.zoom_join_url) return;
        
        navigator.clipboard.writeText(session.zoom_join_url);
        toast({
            title: 'Link Copied!',
            description: 'Zoom join link copied to clipboard',
        });
    };

    // Format date and time
    const formatDate = (dateString: string) => {
        const date = new Date(dateString);
        return date.toLocaleDateString('en-US', {
            weekday: 'long',
            year: 'numeric',
            month: 'long',
            day: 'numeric'
        });
    };

    const formatTime = (dateString: string) => {
        const date = new Date(dateString);
        return date.toLocaleTimeString('en-US', {
            hour: '2-digit',
            minute: '2-digit',
            hour12: true
        });
    };

    if (loading) {
        return (
            <div className="min-h-screen bg-gradient-to-br from-background via-primary/30 to-secondary/30 flex items-center justify-center">
                <div className="text-center">
                    <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-primary mx-auto mb-4"></div>
                    <p className="text-muted-foreground">Loading session...</p>
                </div>
            </div>
        );
    }

    if (!session) {
        return (
            <div className="min-h-screen bg-gradient-to-br from-background via-primary/30 to-secondary/30 flex items-center justify-center">
                <Card className="max-w-md w-full">
                    <CardContent className="p-8 text-center">
                        <h2 className="text-2xl font-bold mb-4">Session not found</h2>
                        <p className="text-muted-foreground mb-6">The session you're looking for doesn't exist.</p>
                        <Button onClick={() => navigate(-1)}>
                            <ChevronLeft className="h-4 w-4 mr-2" />
                            Go Back
                        </Button>
                    </CardContent>
                </Card>
            </div>
        );

    }

    if (session.is_online && session.zoom_join_url) {
        return (
            <div
                className="min-h-screen bg-gradient-to-b from-transparent via-primary/20 to-secondary/50 relative overflow-hidden">
                <div className="absolute inset-0 -z-10">
                    <div
                        className="absolute inset-0 bg-[radial-gradient(hsl(var(--primary))_1px,transparent_1px)] [background-size:20px_20px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_70%,transparent_100%)] opacity-20 dark:opacity-[0.05]"></div>
                </div>
                {/* Back Button */}
                <div className="px-20 pt-8">
                    <Button
                        variant="ghost"
                        onClick={() => navigate(-1)}
                        className="mb-8 text-lg font-medium hover:bg-primary/10 transition-all duration-300 px-4 py-2"
                    >
                        <ChevronLeft className="h-5 w-5 mr-2"/>
                        Back to {session.group_name}
                    </Button>
                </div>
                <div className="container mx-auto px-40 py-8 max-w-6xl">
                    <motion.div
                        initial={{opacity: 0, y: 20}}
                        animate={{opacity: 1, y: 0}}
                        transition={{duration: 0.5}}
                    >

                        {/* Session Statistics */}
                        <div className="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
                            <Card
                                className="bg-gradient-to-br from-card/90 to-card/70 backdrop-blur-md border border-primary/20 hover:border-primary/40 transition-all duration-300">
                                <CardContent className="p-4 text-center">
                                    <div className="p-2 bg-primary/10 rounded-lg w-fit mx-auto mb-2">
                                        <Clock className="h-5 w-5 text-primary"/>
                                    </div>
                                    <p className="text-2xl font-bold text-foreground">{session.duration_minutes}</p>
                                    <p className="text-sm text-muted-foreground">Minutes</p>
                                </CardContent>
                            </Card>
                            <Card
                                className="bg-gradient-to-br from-card/90 to-card/70 backdrop-blur-md border border-primary/20 hover:border-primary/40 transition-all duration-300">
                                <CardContent className="p-4 text-center">
                                    <div className="p-2 bg-secondary/10 rounded-lg w-fit mx-auto mb-2">
                                        <Users className="h-5 w-5 text-secondary"/>
                                    </div>
                                    <p className="text-2xl font-bold text-foreground">--</p>
                                    <p className="text-sm text-muted-foreground">Participants</p>
                                </CardContent>
                            </Card>
                            <Card
                                className="bg-gradient-to-br from-card/90 to-card/70 backdrop-blur-md border border-primary/20 hover:border-primary/40 transition-all duration-300">
                                <CardContent className="p-4 text-center">
                                    <div className="p-2 bg-accent/10 rounded-lg w-fit mx-auto mb-2">
                                        <Calendar className="h-5 w-5 text-accent"/>
                                    </div>
                                    <p className="text-lg font-bold text-foreground">{formatDate(session.datetime).split(',')[1] || formatDate(session.datetime)}</p>
                                    <p className="text-sm text-muted-foreground">Session Date</p>
                                </CardContent>
                            </Card>
                            <Card
                                className="bg-gradient-to-br from-card/90 to-card/70 backdrop-blur-md border border-primary/20 hover:border-primary/40 transition-all duration-300">
                                <CardContent className="p-4 text-center">
                                    <div className="p-2 bg-primary/10 rounded-lg w-fit mx-auto mb-2">
                                        <Badge className="bg-primary text-primary-foreground border-0">
                                            {session.is_online ? 'Online' : 'In-Person'}
                                        </Badge>
                                    </div>
                                    <p className="text-lg font-bold text-foreground capitalize">{session.is_online ? 'Virtual' : 'Physical'}</p>
                                    <p className="text-sm text-muted-foreground">Session Type</p>
                                </CardContent>
                            </Card>
                        </div>

                        {/* RSVP Section */}
                        <Card
                            className="mb-8 bg-gradient-to-br from-card/90 to-card/70 backdrop-blur-md border border-primary/20 hover:border-primary/40 transition-all duration-300">
                            <CardHeader className="pb-4">
                                <div className="flex items-center space-x-3">
                                    <div className="p-2 bg-primary/10 rounded-lg">
                                        <CheckCircle2 className="h-5 w-5 text-primary"/>
                                    </div>
                                    <div>
                                        <h3 className="text-lg font-semibold text-foreground">RSVP</h3>
                                        <p className="text-sm text-muted-foreground">Will you be attending this
                                            session?</p>
                                    </div>
                                </div>
                            </CardHeader>
                            <CardContent className="p-6">
                                {rsvpStatus ? (
                                    <div
                                        className="flex items-center justify-between p-4 bg-muted/20 rounded-lg border border-muted/30">
                                        <div className="flex items-center space-x-3">
                                            <div
                                                className={`p-2 rounded-lg ${rsvpStatus === 'attending' ? 'bg-green-100' : 'bg-red-100'}`}>
                                                <CheckCircle2
                                                    className={`h-5 w-5 ${rsvpStatus === 'attending' ? 'text-green-600' : 'text-red-600'}`}/>
                                            </div>
                                            <div>
                                                <p className="font-semibold text-foreground">
                                                    You
                                                    have {rsvpStatus === 'attending' ? 'confirmed' : 'declined'} attendance
                                                </p>
                                                <p className="text-sm text-muted-foreground">
                                                    {rsvpStatus === 'attending' ? 'See you at the session!' : 'We hope to see you at the next one.'}
                                                </p>
                                            </div>
                                        </div>
                                        <Button
                                            variant="outline"
                                            size="sm"
                                            onClick={() => handleRsvp(rsvpStatus === 'attending' ? 'not_attending' : 'attending')}
                                            disabled={isUpdatingRsvp}
                                            className="border-primary hover:bg-primary/10 transition-all duration-300"
                                        >
                                            {isUpdatingRsvp ? (
                                                <div
                                                    className="animate-spin rounded-full h-4 w-4 border-b-2 border-primary mr-2"></div>
                                            ) : null}
                                            Change RSVP
                                        </Button>
                                    </div>
                                ) : (
                                    <div className="flex flex-col sm:flex-row gap-4">
                                        <Button
                                            onClick={() => handleRsvp('attending')}
                                            disabled={isUpdatingRsvp}
                                            className="flex-1 bg-primary hover:bg-primary/90 text-primary-foreground transition-all duration-300 shadow-lg hover:shadow-xl border-0"
                                        >
                                            {isUpdatingRsvp ? (
                                                <div
                                                    className="animate-spin rounded-full h-4 w-4 border-b-2 border-white mr-2"></div>
                                            ) : (
                                                <CheckCircle2 className="h-5 w-5 mr-2"/>
                                            )}
                                            Yes, I'll attend
                                        </Button>
                                        <Button
                                            onClick={() => handleRsvp('not_attending')}
                                            disabled={isUpdatingRsvp}
                                            variant="outline"
                                            className="flex-1 border-primary hover:bg-primary/10 transition-all duration-300"
                                        >
                                            {isUpdatingRsvp ? (
                                                <div
                                                    className="animate-spin rounded-full h-4 w-4 border-b-2 border-primary mr-2"></div>
                                            ) : (
                                                <X className="h-5 w-5 mr-2"/>
                                            )}
                                            No, I can't make it
                                        </Button>
                                    </div>
                                )}
                            </CardContent>
                        </Card>

                        <Card
                            className="mb-8 overflow-hidden bg-gradient-to-br from-card/90 to-card/70 backdrop-blur-md border border-primary/20 hover:border-primary/40 transition-all duration-300 hover:shadow-xl">
                            <CardHeader
                                className="bg-gradient-to-r from-primary to-secondary text-primary-foreground p-6">
                                <div className="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
                                    <div>
                                        <CardTitle
                                            className="text-3xl sm:text-4xl font-bold mb-3 font-display">{session.title}</CardTitle>
                                        {session.group_name && (
                                            <Link
                                                to={`/group/${session.group_id}`}
                                                className="inline-flex items-center text-primary-foreground/80 hover:text-primary-foreground transition-colors"
                                            >
                                                <Users className="h-4 w-4 mr-2"/>
                                                {session.group_name}
                                            </Link>
                                        )}
                                    </div>
                                    <Badge
                                        className="bg-white/20 text-primary-foreground border-white/30 px-3 py-1 text-sm font-medium">
                                        {session.is_online ? 'Online' : 'In-Person'}
                                    </Badge>
                                </div>
                            </CardHeader>
                            <CardContent className="p-8">
                                {/* Date and Time */}
                                <div className="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
                                    <div className="flex items-start space-x-3">
                                        <div className="p-3 bg-primary/10 rounded-xl border border-primary/20">
                                            <Calendar className="h-6 w-6 text-primary"/>
                                        </div>
                                        <div>
                                            <p className="font-semibold text-lg mb-1">Date</p>
                                            <p className="text-muted-foreground text-base">{formatDate(session.datetime)}</p>
                                        </div>
                                    </div>
                                    <div className="flex items-start space-x-3">
                                        <div className="p-3 bg-secondary/10 rounded-xl border border-secondary/20">
                                            <Clock className="h-6 w-6 text-secondary"/>
                                        </div>
                                        <div>
                                            <p className="font-semibold text-lg mb-1">Time</p>
                                            <p className="text-muted-foreground text-base">
                                                {formatTime(session.datetime)} ({session.duration_minutes} minutes)
                                            </p>
                                        </div>
                                    </div>
                                </div>

                                {/* Location / Meeting Info */}
                                <div className="flex items-start space-x-4 mb-8">
                                    <div className="flex-1">
                                        {session.is_online ? (
                                            <div className="space-y-6">
                                                {session.zoom_join_url ? (
                                                    <div
                                                        className="bg-gradient-to-br from-primary/10 to-secondary/10 border border-primary/20 rounded-xl p-6">
                                                        <div className="flex items-center justify-between mb-6">
                                                            <div className="flex items-center space-x-4">
                                                                <div className="p-3 bg-primary rounded-xl">
                                                                    <Video className="h-6 w-6 text-primary-foreground"/>
                                                                </div>
                                                                <div>
                                                                    <p className="font-semibold text-foreground mb-1">Zoom
                                                                        Meeting</p>
                                                                    <h4 className="text-base text-muted-foreground">Click
                                                                        below to join the session</h4>
                                                                </div>
                                                            </div>
                                                            <Button
                                                                size="sm"
                                                                variant="outline"
                                                                onClick={handleCopyJoinUrl}
                                                                className="h-10 px-3 border-primary hover:bg-primary/10 transition-all duration-300"
                                                            >
                                                                <Copy className="h-4 w-4"/>
                                                            </Button>
                                                        </div>

                                                        <div className="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
                                                            <div
                                                                className="bg-card/50 backdrop-blur-sm rounded-lg p-4 border border-primary/10">
                                                                <p className="text-sm text-primary font-medium mb-2">Meeting
                                                                    ID</p>
                                                                <p className="font-mono text-lg font-semibold">{session.zoom_meeting_id}</p>
                                                            </div>
                                                            {session.zoom_password && (
                                                                <div
                                                                    className="bg-card/50 backdrop-blur-sm rounded-lg p-4 border border-primary/10">
                                                                    <p className="text-sm text-primary font-medium mb-2">Password</p>
                                                                    <p className="font-mono text-lg font-semibold">{session.zoom_password}</p>
                                                                </div>
                                                            )}
                                                        </div>

                                                        <div className="flex flex-col sm:flex-row gap-4">
                                                            <Button
                                                                asChild
                                                                size="lg"
                                                                className="flex-1 bg-primary hover:bg-primary/90 text-primary-foreground transition-all duration-300 shadow-lg hover:shadow-xl border-0"
                                                            >
                                                                <a
                                                                    href={session.zoom_join_url}
                                                                    target="_blank"
                                                                    rel="noopener noreferrer"
                                                                    className="inline-flex items-center justify-center"
                                                                >
                                                                    <Video className="h-5 w-5 mr-3"/>
                                                                    Join Zoom Meeting
                                                                    <ExternalLink className="h-5 w-5 ml-3"/>
                                                                </a>
                                                            </Button>

                                                            <Button
                                                                size="lg"
                                                                variant="outline"
                                                                onClick={handleCopyMeetingInfo}
                                                                className="px-8 border-primary hover:bg-primary/10 transition-all duration-300"
                                                            >
                                                                <Copy className="h-5 w-5 mr-2"/>
                                                                Copy Info
                                                            </Button>
                                                        </div>

                                                        <div className="mt-6 pt-6 border-t border-primary/20">
                                                            <div
                                                                className="flex items-center justify-between text-sm text-muted-foreground">
                                                                <div className="flex items-center space-x-2">
                                                                    <Smartphone className="h-4 w-4"/>
                                                                    <span>Works on desktop and mobile</span>
                                                                </div>
                                                                <a
                                                                    href="https://zoom.us/download"
                                                                    target="_blank"
                                                                    rel="noopener noreferrer"
                                                                    className="text-primary hover:text-primary/80 transition-colors font-medium"
                                                                >
                                                                    Download Zoom app
                                                                </a>
                                                            </div>
                                                        </div>
                                                    </div>
                                                ) : session.meeting_link ? (
                                                    <div
                                                        className="bg-gradient-to-br from-accent/10 to-secondary/10 border border-accent/20 rounded-xl p-6">
                                                        <div className="flex items-center space-x-4 mb-4">
                                                            <div className="p-3 bg-accent rounded-xl">
                                                                <Link2 className="h-6 w-6 text-primary-foreground"/>
                                                            </div>
                                                            <div>
                                                                <h4 className="font-semibold text-foreground text-xl mb-1">Online
                                                                    Meeting</h4>
                                                                <p className="text-base text-muted-foreground">External
                                                                    meeting platform</p>
                                                            </div>
                                                        </div>

                                                        <Button
                                                            asChild
                                                            size="lg"
                                                            className="w-full bg-primary hover:bg-primary/90 text-primary-foreground transition-all duration-300 shadow-lg hover:shadow-xl border-0"
                                                        >
                                                            <a
                                                                href={session.meeting_link}
                                                                target="_blank"
                                                                rel="noopener noreferrer"
                                                                className="inline-flex items-center justify-center"
                                                            >
                                                                <Link2 className="h-5 w-5 mr-3"/>
                                                                Join Meeting
                                                                <ExternalLink className="h-5 w-5 ml-3"/>
                                                            </a>
                                                        </Button>
                                                    </div>
                                                ) : (
                                                    <div
                                                        className="bg-gradient-to-br from-accent/10 to-secondary/10 border border-accent/20 rounded-xl p-6">
                                                        <div
                                                            className="flex items-center space-x-2 text-muted-foreground">
                                                            <Video className="h-5 w-5"/>
                                                            <span className="text-base">Meeting link will be provided by the session host</span>
                                                        </div>
                                                    </div>
                                                )}
                                            </div>
                                        ) : (
                                            <div
                                                className="bg-gradient-to-br from-accent/10 to-secondary/10 border border-accent/20 rounded-xl p-6">
                                                <div className="flex items-center space-x-4">
                                                    <div className="p-3 bg-accent rounded-xl">
                                                        <MapPin className="h-6 w-6 text-primary-foreground"/>
                                                    </div>
                                                    <div>
                                                        <p className="text-base text-muted-foreground">In-Person
                                                            Location</p>
                                                        <h4 className="font-semibold text-foreground text-xl mb-1">
                                                            {session.location || 'Location to be determined'}
                                                        </h4>
                                                    </div>
                                                </div>
                                            </div>
                                        )}
                                    </div>
                                </div>

                                {/* Related Sessions */}
                                <Card
                                    className="mb-8 bg-gradient-to-br from-card/90 to-card/70 backdrop-blur-md border border-primary/20 hover:border-primary/40 transition-all duration-300">
                                    <CardHeader className="pb-4">
                                        <div className="flex items-center justify-between">
                                            <div className="flex items-center space-x-3">
                                                <div className="p-2 bg-primary/10 rounded-lg">
                                                    <Calendar className="h-5 w-5 text-primary"/>
                                                </div>
                                                <div>
                                                    <h3 className="text-lg font-semibold text-foreground">Upcoming
                                                        Sessions</h3>
                                                    <p className="text-sm text-muted-foreground">More sessions
                                                        from {session.group_name}</p>
                                                </div>
                                            </div>
                                            <Button variant="outline" size="sm"
                                                    className="border-primary hover:bg-primary/10 transition-all duration-300"
                                                    onClick={() => navigate(`/group/${session.group_id}`)}>
                                                View All
                                            </Button>
                                        </div>
                                    </CardHeader>
                                    <CardContent className="p-6">
                                        {upcomingSessions.length > 0 ? (
                                            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                                                {upcomingSessions.map((upcomingSession) => (
                                                    <Card key={upcomingSession.id}
                                                          className="bg-gradient-to-br from-card/50 to-card/30 backdrop-blur-sm border border-primary/10 hover:border-primary/30 transition-all duration-300 cursor-pointer"
                                                          onClick={() => navigate(`/session/${upcomingSession.id}`)}>
                                                        <CardContent className="p-4">
                                                            <div className="flex items-start justify-between mb-3">
                                                                <Badge
                                                                    className="bg-primary/20 text-primary border-primary/30 text-xs">
                                                                    Upcoming
                                                                </Badge>
                                                                <div className="text-xs text-muted-foreground">
                                                                    {formatDate(upcomingSession.datetime)}
                                                                </div>
                                                            </div>
                                                            <h4 className="font-semibold text-foreground mb-2">{upcomingSession.title}</h4>
                                                            <p className="text-sm text-muted-foreground mb-3">
                                                                {upcomingSession.description || 'Join this study session to work together'}
                                                            </p>
                                                            <div
                                                                className="flex items-center justify-between text-xs text-muted-foreground">
                                                                <div className="flex items-center space-x-1">
                                                                    <Clock className="h-3 w-3"/>
                                                                    <span>{upcomingSession.duration_minutes || 60} min</span>
                                                                </div>
                                                                <div className="flex items-center space-x-1">
                                                                    <Video className="h-3 w-3"/>
                                                                    <span>{upcomingSession.is_online ? 'Online' : 'In-Person'}</span>
                                                                </div>
                                                            </div>
                                                        </CardContent>
                                                    </Card>
                                                ))}
                                            </div>
                                        ) : (
                                            <div className="text-center py-8">
                                                <div className="p-4 bg-muted/20 rounded-lg w-fit mx-auto mb-4">
                                                    <Calendar className="h-8 w-8 text-muted-foreground"/>
                                                </div>
                                                <h4 className="text-lg font-semibold text-foreground mb-2">No upcoming
                                                    sessions</h4>
                                                <p className="text-muted-foreground">There are no more scheduled
                                                    sessions for this group yet.</p>
                                            </div>
                                        )}
                                    </CardContent>
                                </Card>
                                {session.description && (
                                    <div className="mb-6">
                                        <h4 className="font-medium mb-2">Description</h4>
                                        <p>{session.description}</p>
                                    </div>
                                )}

                                {/* Action Button */}
                                <div className="flex justify-center">
                                    <Button
                                        onClick={handleJoinSession}
                                        disabled={isJoining}
                                        className="bg-primary hover:bg-primary/90 text-primary-foreground px-12 py-4 text-lg font-medium transition-all duration-300 shadow-lg hover:shadow-xl border-0"
                                    >
                                        {isJoining ? (
                                            <>
                                                <div
                                                    className="animate-spin rounded-full h-4 w-4 border-b-2 border-white mr-2"></div>
                                                {session.is_online && session.zoom_join_url ? 'Opening Zoom...' : 'Joining...'}
                                            </>
                                        ) : (
                                            <>
                                                {<>
                                                    <Video className="h-5 w-5 mr-2"/>
                                                    Join Zoom Session
                                                </>}
                                            </>
                                        )}
                                    </Button>
                                </div>
                            </CardContent>
                        </Card>

                        {/* Additional Info Card */}
                        <Card>
                            <CardHeader>
                                <CardTitle className="text-lg">Session Information</CardTitle>
                            </CardHeader>
                            <CardContent>
                                <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                    <div className="flex items-center space-x-2">
                                        <Users className="h-4 w-4 text-muted-foreground"/>
                                        <span className="text-sm text-muted-foreground">Open to all group members</span>
                                    </div>
                                    <div className="flex items-center space-x-2">
                                        <CheckCircle2 className="h-4 w-4 text-muted-foreground"/>
                                        <span className="text-sm text-muted-foreground">Free to attend</span>

                        {/* Group Members & RSVP Status */}
                        <Card className="mb-8 overflow-hidden bg-gradient-to-br from-card/90 to-card/70 backdrop-blur-md border border-primary/20 hover:border-primary/40 transition-all duration-300 hover:shadow-xl">
                            <CardHeader className="bg-gradient-to-r from-primary/10 to-secondary/10 p-6">
                                <div className="flex items-center space-x-3">
                                    <div className="p-2 bg-primary/20 rounded-lg">
                                        <Users className="h-5 w-5 text-primary"/>
                                    </div>
                                    <div>
                                        <CardTitle className="text-lg">Group Members</CardTitle>
                                        <p className="text-sm text-muted-foreground">RSVP status for all group members</p>
                                    </div>
                                </div>
                            </CardHeader>
                            <CardContent className="p-6">
                                {groupMembers.length > 0 ? (
                                    <MemberList members={groupMembers} />
                                ) : (
                                    <div className="text-center py-8">
                                        <Users className="h-12 w-12 text-muted-foreground mx-auto mb-4"/>
                                        <p className="text-muted-foreground">No group members found</p>
                                    </div>
                                )}
                            </CardContent>
                        </Card>
                                    </div>
                                </div>
                            </CardContent>
                        </Card>
                    </motion.div>
                </div>
            </div>
        );
    } else {
        return (
            <div
                className="min-h-screen bg-gradient-to-b from-transparent via-primary/20 to-secondary/50 relative overflow-hidden">
                <div className="absolute inset-0 -z-10">
                    <div
                        className="absolute inset-0 bg-[radial-gradient(hsl(var(--primary))_1px,transparent_1px)] [background-size:20px_20px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_70%,transparent_100%)] opacity-20 dark:opacity-[0.05]"></div>
                </div>
                {/* Back Button */}
                <div className="px-20 pt-8">
                    <Button
                        variant="ghost"
                        onClick={() => navigate(-1)}
                        className="mb-8 text-lg font-medium hover:bg-primary/10 transition-all duration-300 px-4 py-2"
                    >
                        <ChevronLeft className="h-5 w-5 mr-2"/>
                        Back to {session.group_name}
                    </Button>
                </div>
                <div className="container mx-auto px-40 py-8 max-w-6xl">
                    <motion.div
                        initial={{opacity: 0, y: 20}}
                        animate={{opacity: 1, y: 0}}
                        transition={{duration: 0.5}}
                    >

                        {/* Session Statistics */}
                        <div className="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
                            <Card
                                className="bg-gradient-to-br from-card/90 to-card/70 backdrop-blur-md border border-primary/20 hover:border-primary/40 transition-all duration-300">
                                <CardContent className="p-4 text-center">
                                    <div className="p-2 bg-primary/10 rounded-lg w-fit mx-auto mb-2">
                                        <Clock className="h-5 w-5 text-primary"/>
                                    </div>
                                    <p className="text-2xl font-bold text-foreground">{session.duration_minutes}</p>
                                    <p className="text-sm text-muted-foreground">Minutes</p>
                                </CardContent>
                            </Card>
                            <Card
                                className="bg-gradient-to-br from-card/90 to-card/70 backdrop-blur-md border border-primary/20 hover:border-primary/40 transition-all duration-300">
                                <CardContent className="p-4 text-center">
                                    <div className="p-2 bg-secondary/10 rounded-lg w-fit mx-auto mb-2">
                                        <Users className="h-5 w-5 text-secondary"/>
                                    </div>
                                    <p className="text-2xl font-bold text-foreground">--</p>
                                    <p className="text-sm text-muted-foreground">Participants</p>
                                </CardContent>
                            </Card>
                            <Card
                                className="bg-gradient-to-br from-card/90 to-card/70 backdrop-blur-md border border-primary/20 hover:border-primary/40 transition-all duration-300">
                                <CardContent className="p-4 text-center">
                                    <div className="p-2 bg-accent/10 rounded-lg w-fit mx-auto mb-2">
                                        <Calendar className="h-5 w-5 text-accent"/>
                                    </div>
                                    <p className="text-lg font-bold text-foreground">{formatDate(session.datetime).split(',')[1] || formatDate(session.datetime)}</p>
                                    <p className="text-sm text-muted-foreground">Session Date</p>
                                </CardContent>
                            </Card>
                            <Card
                                className="bg-gradient-to-br from-card/90 to-card/70 backdrop-blur-md border border-primary/20 hover:border-primary/40 transition-all duration-300">
                                <CardContent className="p-4 text-center">
                                    <div className="p-2 bg-primary/10 rounded-lg w-fit mx-auto mb-2">
                                        <Badge className="bg-primary text-primary-foreground border-0">
                                            {session.is_online ? 'Online' : 'In-Person'}
                                        </Badge>
                                    </div>
                                    <p className="text-lg font-bold text-foreground capitalize">{session.is_online ? 'Virtual' : 'Physical'}</p>
                                    <p className="text-sm text-muted-foreground">Session Type</p>
                                </CardContent>
                            </Card>
                        </div>

                        {/* RSVP Section */}
                        <Card
                            className="mb-8 bg-gradient-to-br from-card/90 to-card/70 backdrop-blur-md border border-primary/20 hover:border-primary/40 transition-all duration-300">
                            <CardHeader className="pb-4">
                                <div className="flex items-center space-x-3">
                                    <div className="p-2 bg-primary/10 rounded-lg">
                                        <CheckCircle2 className="h-5 w-5 text-primary"/>
                                    </div>
                                    <div>
                                        <h3 className="text-lg font-semibold text-foreground">RSVP</h3>
                                        <p className="text-sm text-muted-foreground">Will you be attending this
                                            session?</p>
                                    </div>
                                </div>
                            </CardHeader>
                            <CardContent className="p-6">
                                {rsvpStatus ? (
                                    <div
                                        className="flex items-center justify-between p-4 bg-muted/20 rounded-lg border border-muted/30">
                                        <div className="flex items-center space-x-3">
                                            <div
                                                className={`p-2 rounded-lg ${rsvpStatus === 'attending' ? 'bg-green-100' : 'bg-red-100'}`}>
                                                <CheckCircle2
                                                    className={`h-5 w-5 ${rsvpStatus === 'attending' ? 'text-green-600' : 'text-red-600'}`}/>
                                            </div>
                                            <div>
                                                <p className="font-semibold text-foreground">
                                                    You
                                                    have {rsvpStatus === 'attending' ? 'confirmed' : 'declined'} attendance
                                                </p>
                                                <p className="text-sm text-muted-foreground">
                                                    {rsvpStatus === 'attending' ? 'See you at the session!' : 'We hope to see you at the next one.'}
                                                </p>
                                            </div>
                                        </div>
                                        <Button
                                            variant="outline"
                                            size="sm"
                                            onClick={() => handleRsvp(rsvpStatus === 'attending' ? 'not_attending' : 'attending')}
                                            disabled={isUpdatingRsvp}
                                            className="border-primary hover:bg-primary/10 transition-all duration-300"
                                        >
                                            {isUpdatingRsvp ? (
                                                <div
                                                    className="animate-spin rounded-full h-4 w-4 border-b-2 border-primary mr-2"></div>
                                            ) : null}
                                            Change RSVP
                                        </Button>
                                    </div>
                                ) : (
                                    <div className="flex flex-col sm:flex-row gap-4">
                                        <Button
                                            onClick={() => handleRsvp('attending')}
                                            disabled={isUpdatingRsvp}
                                            className="flex-1 bg-primary hover:bg-primary/90 text-primary-foreground transition-all duration-300 shadow-lg hover:shadow-xl border-0"
                                        >
                                            {isUpdatingRsvp ? (
                                                <div
                                                    className="animate-spin rounded-full h-4 w-4 border-b-2 border-white mr-2"></div>
                                            ) : (
                                                <CheckCircle2 className="h-5 w-5 mr-2"/>
                                            )}
                                            Yes, I'll attend
                                        </Button>
                                        <Button
                                            onClick={() => handleRsvp('not_attending')}
                                            disabled={isUpdatingRsvp}
                                            variant="outline"
                                            className="flex-1 border-primary hover:bg-primary/10 transition-all duration-300"
                                        >
                                            {isUpdatingRsvp ? (
                                                <div
                                                    className="animate-spin rounded-full h-4 w-4 border-b-2 border-primary mr-2"></div>
                                            ) : (
                                                <X className="h-5 w-5 mr-2"/>
                                            )}
                                            No, I can't make it
                                        </Button>
                                    </div>
                                )}
                            </CardContent>
                        </Card>

                        <Card
                            className="mb-8 overflow-hidden bg-gradient-to-br from-card/90 to-card/70 backdrop-blur-md border border-primary/20 hover:border-primary/40 transition-all duration-300 hover:shadow-xl">
                            <CardHeader
                                className="bg-gradient-to-r from-primary to-secondary text-primary-foreground p-6">
                                <div className="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
                                    <div>
                                        <CardTitle
                                            className="text-3xl sm:text-4xl font-bold mb-3 font-display">{session.title}</CardTitle>
                                        {session.group_name && (
                                            <Link
                                                to={`/group/${session.group_id}`}
                                                className="inline-flex items-center text-primary-foreground/80 hover:text-primary-foreground transition-colors"
                                            >
                                                <Users className="h-4 w-4 mr-2"/>
                                                {session.group_name}
                                            </Link>
                                        )}
                                    </div>
                                    <Badge
                                        className="bg-white/20 text-primary-foreground border-white/30 px-3 py-1 text-sm font-medium">
                                        {session.is_online ? 'Online' : 'In-Person'}
                                    </Badge>
                                </div>
                            </CardHeader>
                            <CardContent className="p-8">
                                {/* Date and Time */}
                                <div className="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
                                    <div className="flex items-start space-x-3">
                                        <div className="p-3 bg-primary/10 rounded-xl border border-primary/20">
                                            <Calendar className="h-6 w-6 text-primary"/>
                                        </div>
                                        <div>
                                            <p className="font-semibold text-lg mb-1">Date</p>
                                            <p className="text-muted-foreground text-base">{formatDate(session.datetime)}</p>
                                        </div>
                                    </div>
                                    <div className="flex items-start space-x-3">
                                        <div className="p-3 bg-secondary/10 rounded-xl border border-secondary/20">
                                            <Clock className="h-6 w-6 text-secondary"/>
                                        </div>
                                        <div>
                                            <p className="font-semibold text-lg mb-1">Time</p>
                                            <p className="text-muted-foreground text-base">
                                                {formatTime(session.datetime)} ({session.duration_minutes} minutes)
                                            </p>
                                        </div>
                                    </div>
                                </div>

                                {/* Location / Meeting Info */}
                                <div className="flex items-start space-x-4 mb-8">
                                    <div className="flex-1">
                                        {session.is_online ? (
                                            <div className="space-y-6">
                                                {session.zoom_join_url ? (
                                                    <div
                                                        className="bg-gradient-to-br from-primary/10 to-secondary/10 border border-primary/20 rounded-xl p-6">
                                                        <div className="flex items-center justify-between mb-6">
                                                            <div className="flex items-center space-x-4">
                                                                <div className="p-3 bg-primary rounded-xl">
                                                                    <Video className="h-6 w-6 text-primary-foreground"/>
                                                                </div>
                                                                <div>
                                                                    <p className="font-semibold text-foreground mb-1">Zoom
                                                                        Meeting</p>
                                                                    <h4 className="text-base text-muted-foreground">Click
                                                                        below to join the session</h4>
                                                                </div>
                                                            </div>
                                                            <Button
                                                                size="sm"
                                                                variant="outline"
                                                                onClick={handleCopyJoinUrl}
                                                                className="h-10 px-3 border-primary hover:bg-primary/10 transition-all duration-300"
                                                            >
                                                                <Copy className="h-4 w-4"/>
                                                            </Button>
                                                        </div>

                                                        <div className="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
                                                            <div
                                                                className="bg-card/50 backdrop-blur-sm rounded-lg p-4 border border-primary/10">
                                                                <p className="text-sm text-primary font-medium mb-2">Meeting
                                                                    ID</p>
                                                                <p className="font-mono text-lg font-semibold">{session.zoom_meeting_id}</p>
                                                            </div>
                                                            {session.zoom_password && (
                                                                <div
                                                                    className="bg-card/50 backdrop-blur-sm rounded-lg p-4 border border-primary/10">
                                                                    <p className="text-sm text-primary font-medium mb-2">Password</p>
                                                                    <p className="font-mono text-lg font-semibold">{session.zoom_password}</p>
                                                                </div>
                                                            )}
                                                        </div>

                                                        <div className="flex flex-col sm:flex-row gap-4">
                                                            <Button
                                                                asChild
                                                                size="lg"
                                                                className="flex-1 bg-primary hover:bg-primary/90 text-primary-foreground transition-all duration-300 shadow-lg hover:shadow-xl border-0"
                                                            >
                                                                <a
                                                                    href={session.zoom_join_url}
                                                                    target="_blank"
                                                                    rel="noopener noreferrer"
                                                                    className="inline-flex items-center justify-center"
                                                                >
                                                                    <Video className="h-5 w-5 mr-3"/>
                                                                    Join Zoom Meeting
                                                                    <ExternalLink className="h-5 w-5 ml-3"/>
                                                                </a>
                                                            </Button>

                                                            <Button
                                                                size="lg"
                                                                variant="outline"
                                                                onClick={handleCopyMeetingInfo}
                                                                className="px-8 border-primary hover:bg-primary/10 transition-all duration-300"
                                                            >
                                                                <Copy className="h-5 w-5 mr-2"/>
                                                                Copy Info
                                                            </Button>
                                                        </div>

                                                        <div className="mt-6 pt-6 border-t border-primary/20">
                                                            <div
                                                                className="flex items-center justify-between text-sm text-muted-foreground">
                                                                <div className="flex items-center space-x-2">
                                                                    <Smartphone className="h-4 w-4"/>
                                                                    <span>Works on desktop and mobile</span>
                                                                </div>
                                                                <a
                                                                    href="https://zoom.us/download"
                                                                    target="_blank"
                                                                    rel="noopener noreferrer"
                                                                    className="text-primary hover:text-primary/80 transition-colors font-medium"
                                                                >
                                                                    Download Zoom app
                                                                </a>
                                                            </div>
                                                        </div>
                                                    </div>
                                                ) : session.meeting_link ? (
                                                    <div
                                                        className="bg-gradient-to-br from-accent/10 to-secondary/10 border border-accent/20 rounded-xl p-6">
                                                        <div className="flex items-center space-x-4 mb-4">
                                                            <div className="p-3 bg-accent rounded-xl">
                                                                <Link2 className="h-6 w-6 text-primary-foreground"/>
                                                            </div>
                                                            <div>
                                                                <h4 className="font-semibold text-foreground text-xl mb-1">Online
                                                                    Meeting</h4>
                                                                <p className="text-base text-muted-foreground">External
                                                                    meeting platform</p>
                                                            </div>
                                                        </div>

                                                        <Button
                                                            asChild
                                                            size="lg"
                                                            className="w-full bg-primary hover:bg-primary/90 text-primary-foreground transition-all duration-300 shadow-lg hover:shadow-xl border-0"
                                                        >
                                                            <a
                                                                href={session.meeting_link}
                                                                target="_blank"
                                                                rel="noopener noreferrer"
                                                                className="inline-flex items-center justify-center"
                                                            >
                                                                <Link2 className="h-5 w-5 mr-3"/>
                                                                Join Meeting
                                                                <ExternalLink className="h-5 w-5 ml-3"/>
                                                            </a>
                                                        </Button>
                                                    </div>
                                                ) : (
                                                    <div
                                                        className="bg-gradient-to-br from-accent/10 to-secondary/10 border border-accent/20 rounded-xl p-6">
                                                        <div
                                                            className="flex items-center space-x-2 text-muted-foreground">
                                                            <Video className="h-5 w-5"/>
                                                            <span className="text-base">Meeting link will be provided by the session host</span>
                                                        </div>
                                                    </div>
                                                )}
                                            </div>
                                        ) : (
                                            <div
                                                className="bg-gradient-to-br from-accent/10 to-secondary/10 border border-accent/20 rounded-xl p-6">
                                                <div className="flex items-center space-x-4">
                                                    <div className="p-3 bg-accent rounded-xl">
                                                        <MapPin className="h-6 w-6 text-primary-foreground"/>
                                                    </div>
                                                    <div>
                                                        <p className="text-base text-muted-foreground">In-Person
                                                            Location</p>
                                                        <h4 className="font-semibold text-foreground text-xl mb-1">
                                                            {session.location || 'Location to be determined'}
                                                        </h4>
                                                    </div>
                                                </div>
                                            </div>
                                        )}
                                    </div>
                                </div>

                                {/* Related Sessions */}
                                <Card
                                    className="mb-8 bg-gradient-to-br from-card/90 to-card/70 backdrop-blur-md border border-primary/20 hover:border-primary/40 transition-all duration-300">
                                    <CardHeader className="pb-4">
                                        <div className="flex items-center justify-between">
                                            <div className="flex items-center space-x-3">
                                                <div className="p-2 bg-primary/10 rounded-lg">
                                                    <Calendar className="h-5 w-5 text-primary"/>
                                                </div>
                                                <div>
                                                    <h3 className="text-lg font-semibold text-foreground">Upcoming
                                                        Sessions</h3>
                                                    <p className="text-sm text-muted-foreground">More sessions
                                                        from {session.group_name}</p>
                                                </div>
                                            </div>
                                            <Button variant="outline" size="sm"
                                                    className="border-primary hover:bg-primary/10 transition-all duration-300"
                                                    onClick={() => navigate(`/group/${session.group_id}`)}>
                                                View All
                                            </Button>
                                        </div>
                                    </CardHeader>
                                    <CardContent className="p-6">
                                        {upcomingSessions.length > 0 ? (
                                            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                                                {upcomingSessions.map((upcomingSession) => (
                                                    <Card key={upcomingSession.id}
                                                          className="bg-gradient-to-br from-card/50 to-card/30 backdrop-blur-sm border border-primary/10 hover:border-primary/30 transition-all duration-300 cursor-pointer"
                                                          onClick={() => navigate(`/session/${upcomingSession.id}`)}>
                                                        <CardContent className="p-4">
                                                            <div className="flex items-start justify-between mb-3">
                                                                <Badge
                                                                    className="bg-primary/20 text-primary border-primary/30 text-xs">
                                                                    Upcoming
                                                                </Badge>
                                                                <div className="text-xs text-muted-foreground">
                                                                    {formatDate(upcomingSession.datetime)}
                                                                </div>
                                                            </div>
                                                            <h4 className="font-semibold text-foreground mb-2">{upcomingSession.title}</h4>
                                                            <p className="text-sm text-muted-foreground mb-3">
                                                                {upcomingSession.description || 'Join this study session to work together'}
                                                            </p>
                                                            <div
                                                                className="flex items-center justify-between text-xs text-muted-foreground">
                                                                <div className="flex items-center space-x-1">
                                                                    <Clock className="h-3 w-3"/>
                                                                    <span>{upcomingSession.duration_minutes || 60} min</span>
                                                                </div>
                                                                <div className="flex items-center space-x-1">
                                                                    <Video className="h-3 w-3"/>
                                                                    <span>{upcomingSession.is_online ? 'Online' : 'In-Person'}</span>
                                                                </div>
                                                            </div>
                                                        </CardContent>
                                                    </Card>
                                                ))}
                                            </div>
                                        ) : (
                                            <div className="text-center py-8">
                                                <div className="p-4 bg-muted/20 rounded-lg w-fit mx-auto mb-4">
                                                    <Calendar className="h-8 w-8 text-muted-foreground"/>
                                                </div>
                                                <h4 className="text-lg font-semibold text-foreground mb-2">No upcoming
                                                    sessions</h4>
                                                <p className="text-muted-foreground">There are no more scheduled
                                                    sessions for this group yet.</p>
                                            </div>
                                        )}
                                    </CardContent>
                                </Card>
                                {session.description && (
                                    <div className="mb-6">
                                        <h4 className="font-medium mb-2">Description</h4>
                                        <p>{session.description}</p>
                                    </div>
                                )}

                                {/* Action Button */}
                                {session.is_online && (
                                    <div className="flex justify-center">
                                        <Button
                                            onClick={handleJoinSession}
                                            disabled={isJoining}
                                            className="bg-primary hover:bg-primary/90 text-primary-foreground px-12 py-4 text-lg font-medium transition-all duration-300 shadow-lg hover:shadow-xl border-0"
                                        >
                                            {isJoining ? (
                                                <>
                                                    <div
                                                        className="animate-spin rounded-full h-4 w-4 border-b-2 border-white mr-2"></div>
                                                    {session.zoom_join_url ? 'Opening Zoom...' : 'Joining...'}
                                                </>
                                            ) : (
                                                <>
                                                    <UserPlus className="h-5 w-5 mr-2"/>
                                                    Join Online Session
                                                </>
                                            )}
                                        </Button>
                                    </div>
                                )}
                            </CardContent>
                        </Card>

                        {/* Additional Info Card */}
                        <Card>
                            <CardHeader>
                                <CardTitle className="text-lg">Session Information</CardTitle>
                            </CardHeader>
                            <CardContent>
                                <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                    <div className="flex items-center space-x-2">
                                        <Users className="h-4 w-4 text-muted-foreground"/>
                                        <span className="text-sm text-muted-foreground">Open to all group members</span>
                                    </div>
                                    <div className="flex items-center space-x-2">
                                        <CheckCircle2 className="h-4 w-4 text-muted-foreground"/>
                                        <span className="text-sm text-muted-foreground">Free to attend</span>
                                    </div>
                                </div>
                            </CardContent>
                        </Card>
                    </motion.div>
                </div>
            </div>
        );
    }
};

export default Session;
